<?xml version="1.0" encoding="utf-8"?>
<component name="HomeScreen" extends="BaseScreen">
    <script type="text/brightscript" uri="HomeScreen.brs" />
    <interface>
        <!-- <function name="loadContinueWatching" /> -->
        
    </interface>
    <children>

        <!-- Clip anything above y=0 so carousel doesn't ghost above screen -->
        <Rectangle
            id="clipMask"
            width="1920"
            height="1080"
            color="0x00000000"
            clippingRect="[0, 0, 1920, 1080]">

            <LayoutGroup
                id="mainLayout"
                translation="[60, 20]"
                layoutDirection="vert"
                >

                <!-- ═══ Carousel ═══ -->
                <Carousel id="carousel" />

                <!-- ═══ Continue Watching ═══ -->
                <RowList
                    id="continueWatching"
                    muteAudioGuide="true"
                    itemSize="[1200, 650]"
                    rowItemSize="[[350, 200]]"
                    showRowLabel="[true]"
                    rowLabelOffset="[[0, 30]]"
                    itemSpacing="[30, 90]"
                    rowHeights="[270]"
                    numRows="1"
                    rowitemSpacing="[[40, 20]]"
                    itemComponentName="RowListItem"
                    drawFocusFeedback="true"
                    visible="false"
                    rowTitleComponentName="rowTitle" />
                
               <HeroPreview id="HeroPreview"/>

                <!-- ═══ Main Row List ═══ -->
                <RowList
                    id="rowList"
                    muteAudioGuide="true"
                    itemSize="[1200, 650]"
                    rowItemSize="[[350, 200],[350, 200],[350, 200],[350, 200],[350, 200],[350, 200],[350, 200]]"
                    showRowLabel="[true]"
                    rowLabelOffset="[[0, 30]]"
                    itemSpacing="[30, 90]"
                    rowHeights="[270, 270, 270, 270, 270, 270,270]"
                    numRows="7"
                    rowitemSpacing="[[40, 20]]"
                    itemComponentName="RowListItem"
                    drawFocusFeedback="true"
                    vertFocusAnimationStyle="fixedFocus"
                    rowFocusAnimationStyle="floatingFocus"
                    rowTitleComponentName="rowTitle" />

            </LayoutGroup>

        </Rectangle>
        <!-- <ShimmerScreen
                id="shimmer"
                rectWidth="200"
                rectHeight="250" /> -->

        <Timer id="startupTimer" duration="0.3" repeat="false" />

    </children>
</component>