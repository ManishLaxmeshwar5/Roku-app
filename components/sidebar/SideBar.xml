<component name="SideBar" extends="BaseScreen">
    <script type="text/brightscript" uri="pkg:/components/sidebar/SideBar.brs" />
    <interface>
        <field id="selectedIndex" type="integer" alwaysNotify="true" />
        <field id="collapsed" type="boolean" value="false" alwaysNotify="true" onChange="onCollapsedChanged"/>
        <field id="isOpen" type="bool" />
    </interface>

    <children>
    <Group id="slideWrapper">
        <Rectangle
            id="bg"
            width="170"
            height="720"
            color="0x00000000"/>
        <Group id ="gradientBg"
            />
        <MarkupList
            translation="[0,150]"
            id="menu"
            muteAudioGuide="true"
            itemSize="[190,90]"
            drawFocusFeedback="false"
            itemComponentName="SideBarItem"
            vertFocusAnimationStyle="floatingFocus"/>
        </Group>

    <Animation id="sidebarAnim" duration="0.3" easeFunction="inOutCubic" repeat="false">
        <FloatFieldInterpolator id="widthInterp"    fieldToInterp="bg.width"         key="[0,1]" keyValue="[370,370]" />
        <FloatFieldInterpolator id="gradientInterp" fieldToInterp="gradientBg.opacity" key="[0,1]" keyValue="[1.0,1.0]" />
       
    </Animation>


    
    </children>
</component>