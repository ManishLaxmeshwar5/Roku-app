<?xml version="1.0" encoding="utf-8"?>
<component name="Carousel" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/UIComponents/Carousel.brs" />
    <interface>
        <field id="content" type="node" onChange="showShimmer" />
        <!-- <field id="content" type="node" onChange="onContentSet"/> -->
        <field id="itemSelected"    type="integer" value="-1" />
        <field id="focusedIndex"    type="integer" value="0" />

    </interface>
    <children>
        <Poster
            id="heroPoster"
            translation="[0,0]"
            width="1280"
            height="450"
            
            />
        <Label  
            id="titleLabel"
            translation="[60,310]"
            width="800"
            height="60"
            font="font:LargeBoldSystemFont"
            color="0xFFFFFFFF"/>
        <Label
            id="descLabel"
            translation="[60,350]"
            width="900"
            height="40"
            font= "font:SmallSystemFont"
            color="0xCCCCCCFF"/>
        
        <Button
                id="carouselbutton"
                text="WATCH NOW"
                showFocusFootprint="true"
                focusable="true"
                translation="[60,380]"
                focusedIconUri = "pkg:/images/play-button-arrowhead-removebg-preview.png"
                />

        <Group id="dotsGroup" translation="[530,465]"/>
            <Label
                id="arrowLeft"
                translation="[10, 175]"
                text="&#x276E;"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFAA"
                opacity="0.0"
            />

            <!-- Right arrow -->
            <Label
                id="arrowRight"
                translation="[1230, 175]"
                text="&#x276F;"
                font="font:LargeBoldSystemFont"
                color="0xFFFFFFAA"
                opacity="0.0"
            />
        <Timer id="autoTimer" duration="5" repeat="true"/>

        <Animation id ="fadeAnim" duration="0.9" easeFunction="Linear">
        <FloatFieldInterpolator
            id ="fadeInterp"
            key="[0.0,1.0]"
            keyvalue="[0.0,1.0]"
            fieldToInterp ="heroPoster.opacity"/>

        </Animation>
        <ShimmerScreen
            id="shimmer"
            rectWidth="1280"
            rectHeight="450" />
        <ShimmerScreen id="shimmerTitle"
            rectWidth="500"
            rectHeight="40"
            translation="[60,318]" />
        <ShimmerScreen id="shimmerDesc"
            rectWidth="700"
            rectHeight="28"
            translation="[60,378]" />
    </children>
</component>