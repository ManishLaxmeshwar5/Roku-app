<?xml version= "1.0" encoding="utf-8"?>
<component name="HeroPreview" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/UIComponents/UIHeroPreview.brs" />
    <interface>
        <field id="posterUrl" type="string" onChange="onPosterUrlChanged"/>
        <field id="heroTitle" type="string" onChange="onHeroTitleChanged" />
        <field id="heroDesc"  type="string" onChange="onHeroDescChanged"  />

    </interface>
    <children>
        <Poster
            id="heroPreview"
            translation="[50,0]"
            width="1200"
            height="350"
            uri ="pkg:/images/misurina-sunset.jpg"/>
        <Label 
            id="titleLabel"
            translation="[60,260]"
            width="800"
            height="60"
            font= "font:LargeBoldSystemFont"
            color="0xFFFFFFFF"/>
        <Label 
            text="New Arrivals"
            translation="[60,20]"
            width="800"
            height="60"
            font= "font:LargeSystemFont"
            color="0xFFFFFFFF"/>
        <Label
            id="descLabel"
            translation="[60,300]"
            width="900"
            height="40"
            font="font:SmallSystemFont"
            color="0xCCCCCCFF"/>
    </children>
</component>