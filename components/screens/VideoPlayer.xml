<?xml version = "1.0" encoding ="utf-9"?>

<component name="VideoPlayer" extends="Group" initialFocus="videoNode">
    <interface>
        <field id="videoContent" type="assocArray" onChange ="onContentSet"/>
        <field id="events" type="assocArray" />
        <field id="requestFocus" type="boolean" onChange="handleFocus" />
        
    </interface>
    <script type="text/brightscript" uri="VideoPlayer.brs" />
    <script type="text/brightscript" uri="pkg:/components/utils.brs" />
    <script type="text/brightscript" uri="pkg:/components/ViewModel/VideoPlayerViewModel.brs" />
        <script type="text/brightscript" uri="pkg:/components/Models/BookmarkModel.brs" />
        <script type="text/brightscript" uri="pkg:/components/Models/MuxModel.brs" />
    
    <children>
        <Video 
            id="videoNode"
            translation="[0,0]"
            width="1280"
            height="720"
            loop="false" 
            enableUI="true"
            focusable="true"/>
    </children>
</component>