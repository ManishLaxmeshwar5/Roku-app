<?xml version ="1.0" encoding="utf-8"?>
<component name="DetailScreen" extends = "BaseScreen" initialFocus="rowList">
    <script type="text/brightscript" uri="pkg:/components/screens/DetailScreen.brs" />
    <script type="text/brightscript" uri="pkg:/components/ViewModel/DetailViewModel.brs" />
    <script type="text/brightscript" uri="pkg:/components/Models/WatchLaterModel.brs" />
    
    <interface>
        <field id="itemContent" type="node"  onChange = "onContentChanged"/>
        <field id="continueWatching" type="boolean" />
    </interface>

    <children>
        <Poster 
            id= "bgPoster" 
            width="1280"
            height="720"
            />
        <Rectangle
            id="background"
            color="0x000000AA"
            focusable="false"
            height="720"
            width="1280" />

        <LayoutGroup
            id="mainLayout"
            layoutDirection="horiz"
            translation="[182,164]"
            >

        <Poster
            id="detailPoster"
            width="220"
            height="320"
            translation="[0,20]"
        />
        </LayoutGroup>
        <!-- <LayoutGroup
            id="contentLayout"
            layoutDirection ="vert"
            vertAlign = "top"
            
            > -->

            <Label
                id="detailTitle"
                font="font:LargeBoldSystemFont"
                width="768"
                color="0xFFFFFFFF"
                horizAlign="left"
                translation="[430,164]"/>

            <Label
                id="detailDescription"
                font="font:MediumSystemFont"
                width="762"
                height="100"
                color="0xCCCCCCFF"
                horizAlign="left"
                wrap="true"
                numLines="5" 
                translation="[430,214]"/>
                
            
            <Button
                id="rowList"
                text="WATCH NOW"
                showFocusFootprint="true"
                focusable="true"
                translation="[430,400]"
                focusedIconUri = "pkg:/images/play-button-arrowhead-removebg-preview.png"
                />
            <Group
                id="watchLaterGroup"
                focusable="true"
                translation="[680,405]">

                <Rectangle
                    id="watchLaterBg"
                    width="60"
                    height="56"
                    color="0x00000000"
                    />

                <Poster
                    id="watchLaterIcon"
                    width="35"
                    height="35"
                    opacity="0.5"
                    uri="pkg:/images/watch_later.png"
                    translation="[13,12]"
                    />
            </Group>
            
        
    </children>
</component>