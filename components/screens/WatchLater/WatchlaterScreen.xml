<?xml version="1.0" encoding="utf-8"?>
<component name="WatchlaterScreen" extends="Group">
    <script type="text/brightscript" uri="WatchlaterScreen.brs" />
    <script type="text/brightscript" uri="pkg:/components/utils.brs" />
    <script type="text/brightscript" uri="pkg:/components/ViewModel/WatchLaterViewModel.brs" />
    <script type="text/brightscript" uri="../../Models/WatchLaterModel.brs" />
    <interface>
        <field id="events" type="assocArray" alwaysNotify="true"/>
    </interface>
    <children>
        <Label
            id="screenTitle"
            text="Watch Later"
            font= "font:MediumBoldSystemFont"
            color="0xFFFFFFFF"
            translation="[80,60]"
            />

            <RowList
            id="watchLaterGrid"
            translation="[100,130]"
            itemSize="[1150, 300]"
            itemSpacing="[50,100]"
            numRows="3"
            muteAudioGuide="true"
            rowItemSize="[[200, 250]]"
            rowItemSpacing="[[29, 50]]"
            rowLabelOffset="[[0, 15]]"
            drawFocusFeedback="true"
            focusBitmapBlendColor="0x00BFFFFF"
            rowFocusAnimationStyle="floatingFocus"
            itemComponentName="UIRowListItem"
            />
        <Label
            id="emptyLabel"
            text="Your WatchLater List is empty..."
            color="0xAAAAAAFF"
            translation="[460,380]"
            visible="false"
            />
    </children>
</component>