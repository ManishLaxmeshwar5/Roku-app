<?xml version = "1.0" encoding = "utf-8"?>
<component name="MovieScreenItem" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/screens/MovieScreen/MovieScreenItem.brs" />
    <interface>
        <field id="itemContent" type="node" />
    </interface>
    <children>
            <ShimmerScreen
                id="shimmer"
                rectWidth="200"
                rectHeight="250" />
        <Rectangle
            id="focusBg"
            width="200"
            height="250"
            color="0x00BFFF00"
            visible="false" />

        
        <Poster
            id="poster"
            width="200"
            height="250"
            translation="[0, 0]" />

        
        <Label
            id="title"
            translation="[0, 270]"
            font="font:SmallBoldSystemFont"
            color="0xFFFFFFFF"
            maxLines="1" />
    </children>
</component>