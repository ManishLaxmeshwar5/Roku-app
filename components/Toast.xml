<?xml version="1.0" encoding="utf-8"?>
<component name="Toast" extends="Group">
    <script type="text/brightscript" uri="Toast.brs" />
    <children>
    <Group id="toastBg" translation="[100,0]">
        <Poster
            uri="pkg:/images/toast2.png"
            width="800"
            height="270"
            blendColor="#303234"/>
            <Label
                id="toastLabel"
                translation="[130,0]"
                width="600"
                height="240"
                vertAlign="center"
                font="font:SmallSystemFont"
                color="0xFFFFFFFF"
                leadingEllipsis="false"/>
                </Group>
            <Animation id="slideIn" duration="0.8" repeat="false" easeFunction="outBounce">
            <Vector2DFieldInterpolator
                id="slideInInterp"
                key="[0.0, 1.0]"
                keyValue="[[250, -270], [250, 0]]"
                fieldToInterp="toastBg.translation" />
        </Animation>

            <Animation id="slideOut" duration="0.8" repeat="false" easeFunction="inQuad">
            <Vector2DFieldInterpolator
                id="slideOutInterp"
                key="[0.0, 1.0]"
                keyValue="[[250, 0], [250, -270]]"
                fieldToInterp="toastBg.translation" />
        </Animation>
    </children>
</component>